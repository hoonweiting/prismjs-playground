{
  "name": "prismjs-playground",
  "version": "1.0.0",
  "description": "A sandbox for me to develop and test new themes for prism.js",
  "main": "index.js",
  "scripts": {
    "prebuild": "npm run lint",
    "build": "sergey --root=./src/ --output=../build",
    "lint": "stylelint \"src/*.css\"",
    "watch": "sergey --root=./src/ --output=../build --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hoonweiting/prismjs-playground.git"
  },
  "author": "Wei Ting",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hoonweiting/prismjs-playground/issues"
  },
  "homepage": "https://github.com/hoonweiting/prismjs-playground#readme",
  "devDependencies": {
    "sergey": "0.0.13",
    "stylelint": "^13.13.1",
    "stylelint-config-standard": "^22.0.0"
  }
}
